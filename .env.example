# Azaman Business Portal — Environment Variables
# Copy to .env and fill in before running

# Your Azaman backend URL (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com

# Cloudinary — direct image uploads for products & KYB documents.
# Create an *unsigned* upload preset: Cloudinary Dashboard → Settings → Upload.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
